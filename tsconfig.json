{
  "compilerOptions": {
    "outDir": "dist",
    "sourceMap": true,
    "target": "esnext",
    "module": "commonjs",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "noImplicitAny": true,
    "strict": true,
    "skipLibCheck": true
  },
  "extends": "./.svelte-kit/tsconfig.json",
  "include": ["./api", "./*.js", "src/**/*.ts", "test/**/*.ts"]
}
